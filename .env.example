# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# Supabase Configuration (from Supabase Dashboard > Project Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_key_here

# Channel ID where the verification panel will be posted
WELCOME_CHANNEL_ID=your_welcome_channel_id_here

# Category ID where verification tickets will be created
TICKET_CATEGORY_ID=your_ticket_category_id_here

# Category ID where closed tickets will be moved (optional)
CLOSED_CATEGORY_ID=your_closed_category_id_here

# Role ID to assign after verification (optional)
VERIFIED_ROLE_ID=your_verified_role_id_here

# Keep-alive server port
PORT=3000
